---
import type { FeedItem } from "../data/site";

const { title, subtitle, items } = Astro.props as {
  title: string;
  subtitle: string;
  items: FeedItem[];
};

const tabs = [
  { label: "All", href: "/" },
  { label: "Projects", href: "/projects" },
  { label: "Writing", href: "/writing" },
  { label: "About", href: "/about" }
];
---

<section class="min-h-screen border-x border-zinc-800 bg-black/95 pb-20 lg:pb-0">
  <header class="sticky top-0 z-10 border-b border-zinc-800 bg-black/80 px-4 py-3 backdrop-blur">
    <h2 class="text-xl font-bold text-zinc-50">{title}</h2>
    <p class="text-sm text-zinc-400">{subtitle}</p>
    <div class="mt-3 flex gap-2 overflow-x-auto pb-1">
      {tabs.map((tab) => (
        <a
          href={tab.href}
          class="whitespace-nowrap rounded-full border border-zinc-700 px-3 py-1 text-sm text-zinc-200 hover:border-zinc-500"
        >
          {tab.label}
        </a>
      ))}
    </div>
  </header>

  <div>
    {items.map((item) => (
      <article class="border-b border-zinc-800 px-4 py-5 transition hover:bg-zinc-950/80">
        <div class="flex items-center justify-between text-xs text-zinc-500">
          <span class="uppercase tracking-wide">{item.kind}</span>
          <time datetime={item.date}>{item.date}</time>
        </div>
        <h3 class="mt-2 text-lg font-semibold text-zinc-100">{item.title}</h3>
        <p class="mt-2 text-sm leading-6 text-zinc-300">{item.summary}</p>
        <div class="mt-3 flex flex-wrap gap-2">
          {item.tags.map((tag) => <span class="rounded-full border border-zinc-700 px-2 py-1 text-xs text-zinc-300">{tag}</span>)}
        </div>
        <a href={item.href} class="mt-4 inline-block text-sm font-semibold text-sky-400 hover:text-sky-300">{item.cta} -></a>
      </article>
    ))}
  </div>
</section>
