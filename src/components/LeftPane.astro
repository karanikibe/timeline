---
import { navItems, profile } from "../user/site";

const { activePath } = Astro.props;
---

<aside class="hidden border-r border-zinc-800 bg-black lg:sticky lg:top-0 lg:block lg:h-screen">
  <div class="flex h-full flex-col p-6">
    <img src={profile.avatar} alt={profile.name} class="h-16 w-16 rounded-full object-cover" />
    <div class="mt-3">
      <h1 class="text-xl font-bold text-zinc-50">{profile.name}</h1>
      <p class="text-sm text-zinc-400">{profile.handle}</p>
      <p class="mt-1 text-sm text-zinc-300">{profile.role}</p>
    </div>

    <nav class="mt-7 space-y-1">
      {navItems.map((item) => {
        const active = activePath === item.href;

        return (
          <a
            href={item.href}
            class:list={[
              "block rounded-full px-4 py-3 text-base font-medium transition",
              active
                ? "bg-sky-500 text-white"
                : "text-zinc-100 hover:bg-zinc-900 hover:text-zinc-50"
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="mt-auto border-t border-zinc-800 pt-6 text-sm">
      <div class="flex justify-center gap-4">
        <a href={profile.x} target="_blank" rel="noreferrer" class="text-zinc-400 hover:text-zinc-100" aria-label="X/Twitter">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href={profile.github} target="_blank" rel="noreferrer" class="text-zinc-400 hover:text-zinc-100" aria-label="GitHub">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.53 2.341 1.088 2.91.832.092-.647.351-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.378.202 2.398.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.19 22 16.416 22 12.017 22 6.484 17.522 2 12.002 2z"/></svg>
        </a>
        <a href={profile.linkedin} target="_blank" rel="noreferrer" class="text-zinc-400 hover:text-zinc-100" aria-label="LinkedIn">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.063.925 2.063 2.063 0 1.139-.925 2.065-2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
      <p class="mt-3 text-center text-zinc-500">{profile.location}</p>
    </div>
  </div>
</aside>
