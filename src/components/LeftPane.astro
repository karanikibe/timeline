---
import { navItems, profile } from "../data/site";

const { activePath } = Astro.props;
---

<aside class="hidden border-r border-zinc-800 bg-black lg:sticky lg:top-0 lg:block lg:h-screen">
  <div class="flex h-full flex-col p-6">
    <img src={profile.avatar} alt={profile.name} class="h-16 w-16 rounded-full object-cover" />
    <div class="mt-3">
      <h1 class="text-xl font-bold text-zinc-50">{profile.name}</h1>
      <p class="text-sm text-zinc-400">{profile.handle}</p>
      <p class="mt-1 text-sm text-zinc-300">{profile.role}</p>
    </div>

    <nav class="mt-7 space-y-1">
      {navItems.map((item) => {
        const active = activePath === item.href;

        return (
          <a
            href={item.href}
            class:list={[
              "block rounded-full px-4 py-3 text-base font-medium transition",
              active
                ? "bg-sky-500 text-white"
                : "text-zinc-100 hover:bg-zinc-900 hover:text-zinc-50"
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="mt-auto space-y-3 border-t border-zinc-800 pt-6 text-sm">
      <a class="block rounded-full bg-sky-500 px-4 py-3 text-center font-semibold text-white hover:bg-sky-400" href={profile.resumeUrl} target="_blank" rel="noreferrer">
        View Resume
      </a>
      <p class="text-zinc-500">{profile.location}</p>
    </div>
  </div>
</aside>
