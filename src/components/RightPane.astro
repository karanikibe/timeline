---
import { githubConfig, profile } from "../data/site";
---

<aside class="hidden h-screen overflow-y-auto bg-black p-5 xl:block">
  <section class="rounded-3xl border border-zinc-800 bg-gradient-to-b from-zinc-950 via-black to-zinc-950 p-5 shadow-[0_0_0_1px_rgba(255,255,255,0.02),0_18px_45px_rgba(0,0,0,0.45)]">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-[11px] uppercase tracking-[0.22em] text-zinc-500">Live Feed</p>
        <h3 class="mt-1 text-xl font-semibold text-zinc-100">GitHub Activity</h3>
      </div>
      <a class="rounded-full border border-zinc-700 px-3 py-1 text-xs font-medium text-zinc-300 transition hover:border-zinc-500 hover:text-zinc-100" href={profile.github} target="_blank" rel="noreferrer">Profile</a>
    </div>
    <div class="mt-3 h-px bg-gradient-to-r from-zinc-800 via-zinc-700 to-zinc-800"></div>

    <ul id="github-events" class="mt-4 divide-y divide-zinc-800 text-sm text-zinc-300">
      <li class="text-zinc-500">Loading latest activity...</li>
    </ul>
  </section>

  <script is:inline define:vars={{ username: githubConfig.username, limit: githubConfig.eventsLimit }}>
    const list = document.getElementById("github-events");
    const endpoint = `/api/github-activity?username=${encodeURIComponent(username)}&limit=${limit}`;
    const pluralize = (count, singular, plural) => `${count} ${count === 1 ? singular : plural}`;

    const toLabel = (event) => {
      if (event.type === "PushEvent") {
        const commits = event.commitCount ?? 0;
        if (commits > 0) return `Pushed ${pluralize(commits, "commit", "commits")} to ${event.repo}`;
        return `Made commits to ${event.repo}`;
      }
      if (event.type === "PullRequestEvent") {
        const action = String(event.action || "").toLowerCase();
        if (action === "opened") return `Opened a pull request on ${event.repo}`;
        if (action === "closed") return `Closed a pull request on ${event.repo}`;
        if (action === "reopened") return `Reopened a pull request on ${event.repo}`;
        if (action === "synchronize") return `Updated a pull request on ${event.repo}`;
        return `Worked on a pull request in ${event.repo}`;
      }
      if (event.type === "IssuesEvent") {
        const action = String(event.action || "").toLowerCase();
        if (action === "opened") return `Opened an issue on ${event.repo}`;
        if (action === "closed") return `Closed an issue on ${event.repo}`;
        if (action === "reopened") return `Reopened an issue on ${event.repo}`;
        return `Updated an issue on ${event.repo}`;
      }
      if (event.type === "IssueCommentEvent") return `Left an issue comment on ${event.repo}`;
      if (event.type === "PullRequestReviewCommentEvent") return `Left a PR comment on ${event.repo}`;
      if (event.type === "PullRequestReviewEvent") return `Left a PR review on ${event.repo}`;
      if (event.type === "WatchEvent") return `Starred ${event.repo}`;
      if (event.type === "ForkEvent") return `Forked ${event.repo}`;
      if (event.type === "ReleaseEvent") return `Published a release in ${event.repo}`;
      if (event.type === "CreateEvent") {
        if (event.visibility === "private") return null;
        const detail = typeof event.detail === "string" && event.detail !== "private" ? event.detail : null;
        if (detail) return `Created ${detail} in ${event.repo}`;
        return `Created something in ${event.repo}`;
      }

      return null;
    };

    const toRelative = (value) => {
      const diffMs = Date.now() - new Date(value).getTime();
      const diffMinutes = Math.max(1, Math.floor(diffMs / 60000));
      if (diffMinutes < 60) return `${diffMinutes}m ago`;
      const diffHours = Math.floor(diffMinutes / 60);
      if (diffHours < 24) return `${diffHours}h ago`;
      return `${Math.floor(diffHours / 24)}d ago`;
    };

    const renderEvent = (event) => {
      const item = document.createElement("li");
      item.className = "py-3";

      const row = document.createElement("div");
      row.className = "flex items-start justify-between gap-3";

      const titleLink = document.createElement("a");
      titleLink.className = "leading-6 text-zinc-200 hover:text-zinc-100";
      const label = toLabel(event);
      if (!label) return null;
      titleLink.textContent = label;
      if (event.url) {
        titleLink.href = event.url;
        titleLink.target = "_blank";
        titleLink.rel = "noreferrer";
      }

      const age = document.createElement("p");
      age.className = "shrink-0 text-xs font-medium text-emerald-400";
      age.textContent = toRelative(event.createdAt);

      const textWrap = document.createElement("div");
      textWrap.className = "min-w-0 flex-1 pr-2";
      textWrap.append(titleLink);

      if (event.detail) {
        const detail = document.createElement("p");
        detail.className = "mt-1 text-xs leading-5 text-zinc-400";
        detail.textContent = event.detail;
        detail.style.display = "-webkit-box";
        detail.style.webkitLineClamp = "2";
        detail.style.webkitBoxOrient = "vertical";
        detail.style.overflow = "hidden";
        textWrap.append(detail);
      }

      if (event.type === "PushEvent" && Array.isArray(event.commits) && event.commits.length > 0) {
        const commitList = document.createElement("ul");
        commitList.className = "mt-2 space-y-1 text-xs text-zinc-400";

        for (const commit of event.commits) {
          const commitItem = document.createElement("li");
          const commitLink = document.createElement("a");
          commitLink.className = "inline-flex items-center gap-2 hover:text-zinc-200";
          commitLink.href = commit.url;
          commitLink.target = "_blank";
          commitLink.rel = "noreferrer";
          commitLink.textContent = commit.message;
          commitItem.append(commitLink);
          commitList.append(commitItem);
        }

        if (event.commitCount > event.commits.length && event.compareUrl) {
          const moreItem = document.createElement("li");
          const moreLink = document.createElement("a");
          const remaining = event.commitCount - event.commits.length;
          moreLink.className = "text-sky-400 hover:text-sky-300";
          moreLink.href = event.compareUrl;
          moreLink.target = "_blank";
          moreLink.rel = "noreferrer";
          moreLink.textContent = `+${remaining} more commit${remaining === 1 ? "" : "s"}`;
          moreItem.append(moreLink);
          commitList.append(moreItem);
        }

        textWrap.append(commitList);
      }

      row.append(textWrap, age);
      item.append(row);
      return item;
    };

    fetch(endpoint)
      .then((response) => response.ok ? response.json() : Promise.reject())
      .then((payload) => {
        const events = payload?.events ?? [];

        if (!Array.isArray(events) || events.length === 0) {
          list.innerHTML = '<li class="text-zinc-500">No recent public activity found.</li>';
          return;
        }

        const rendered = events.slice(0, limit).map(renderEvent).filter(Boolean);
        if (rendered.length === 0) {
          list.innerHTML = '<li class="text-zinc-500">No recent high-signal activity found.</li>';
          return;
        }
        list.replaceChildren(...rendered);
      })
      .catch(() => {
        list.innerHTML = '<li class="text-zinc-500">Unable to fetch GitHub activity right now.</li>';
      });
  </script>
</aside>
