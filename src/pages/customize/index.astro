---
import AppShell from "../../layouts/AppShell.astro";
import { pageMeta } from "../../lib/site";
---

<AppShell activePath="/customize" pageTitle="Customize | kakaruto.com" pageDescription="Build your own timeline portfolio">
  <section class="min-h-screen border-x border-zinc-800 bg-black/95 px-5 py-8 pb-20 lg:pb-8">
    <h2 class="text-2xl font-bold text-zinc-50">Customize Your Own</h2>
    <p class="mt-4 max-w-2xl text-zinc-300">
      Timeline is open source. Fork it to build your own portfolio website with the same design.
    </p>

    <div class="mt-8 grid gap-6">
      <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
        <h3 class="text-lg font-semibold text-zinc-100">1. Fork the Repository</h3>
        <p class="mt-2 text-sm text-zinc-400">Clone the timeline repo to get started.</p>
        <pre class="mt-3 overflow-x-auto rounded-lg bg-black p-4 text-xs text-zinc-300"><code>git clone https://github.com/kaka-ruto/timeline.git
cd timeline</code></pre>
      </div>

      <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
        <h3 class="text-lg font-semibold text-zinc-100">2. Customize Your Data</h3>
        <p class="mt-2 text-sm text-zinc-400">Edit the files in <code class="text-zinc-300">src/user/data/</code> to add your own profile, work experience, projects, and writing.</p>
        <ul class="mt-3 space-y-2 text-xs text-zinc-400">
          <li><code class="text-zinc-300">profile.json</code> — Name, bio, avatar, social links</li>
          <li><code class="text-zinc-300">work/*.md</code> — Work experience entries</li>
          <li><code class="text-zinc-300">projects/*.md</code> — Project showcases</li>
          <li><code class="text-zinc-300">writing/*.md</code> — Blog posts or articles</li>
        </ul>
      </div>

      <div class="rounded-xl border border-zinc-800 bg-zinc-950 p-5">
        <h3 class="text-lg font-semibold text-zinc-100">3. Deploy</h3>
        <p class="mt-2 text-sm text-zinc-400">Push to GitHub and connect to Cloudflare Pages for free hosting.</p>
        <pre class="mt-3 overflow-x-auto rounded-lg bg-black p-4 text-xs text-zinc-300"><code>git add .
git commit -m "My portfolio"
git push</code></pre>
      </div>
    </div>

    <div class="mt-10">
      <a href="https://github.com/kaka-ruto/timeline" target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 rounded-full border border-zinc-700 px-4 py-2 text-sm font-medium text-zinc-200 transition hover:border-zinc-500 hover:text-white">
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        View on GitHub
      </a>
    </div>
  </section>
</AppShell>