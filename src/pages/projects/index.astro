---
import AppShell from "../../layouts/AppShell.astro";
import { getCollection } from "astro:content";

const projectEntries = await getCollection("projects");
const sortedProjects = projectEntries.sort((a, b) => 
  new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime()
);

const dayParts = (value: Date) => {
  const parts = String(value).split(/[-T]/).map((part, i) => ({
    type: (["year", "month", "day", "time"][i] ?? "time") as string,
    value: part.split(" ")[0]
  }));
  return {
    year: Number(parts.find((part) => part.type === "year")?.value ?? "0"),
    month: Number(parts.find((part) => part.type === "month")?.value ?? "0"),
    day: Number(parts.find((part) => part.type === "day")?.value ?? "0")
  };
};

const daysAgoText = (value: string) => {
  if (!value || !value.includes("/")) return value;
  const nowParts = dayParts(new Date());
  const parts = value.split("/").map(Number);
  const year = parts[0];
  const month = parts[1];
  const day = parts[2];
  if (!year || !month || !day) return value;
  const nowUtc = Date.UTC(nowParts.year, nowParts.month - 1, nowParts.day);
  const entryUtc = Date.UTC(year, month - 1, day);
  const diff = Math.max(0, Math.floor((nowUtc - entryUtc) / 86400000));
  if (diff === 0) return "today";
  if (diff === 1) return "1 day ago";
  if (diff < 30) return `${diff} days ago`;
  if (diff < 365) return `${Math.floor(diff / 30)} months ago`;
  return `${Math.floor(diff / 365)} years ago`;
};
---

<AppShell activePath="/projects" pageTitle="Projects | Kaka Ruto" pageDescription="Projects by Kaka Ruto.">
  <section class="min-h-screen border-x border-zinc-800 bg-black/95 px-5 py-8 pb-20 lg:pb-8">
    <header class="border-b border-zinc-800 pb-6">
      <h2 class="text-2xl font-bold text-zinc-50">Projects</h2>
      <p class="mt-2 text-zinc-400">Products and systems I have built.</p>
    </header>
    
    <div class="-mx-5">
      {sortedProjects.map((entry, i) => (
        <div class:list={["px-5 py-5", i < sortedProjects.length - 1 && "border-b border-zinc-800"]}>
          <div class="flex items-baseline justify-between gap-x-4">
            <a href={entry.data.url} target="_blank" rel="noreferrer" class="text-base font-semibold text-blue-400">{entry.data.name}</a>
            <div class="text-sm text-emerald-400 shrink-0">{daysAgoText(entry.data.startDate)}</div>
          </div>
          <p class="mt-1 text-sm font-medium text-zinc-200">{entry.data.description}</p>
          
          <ul class="mt-3 space-y-1.5">
            {entry.body.split("\n").filter(line => line.trim().startsWith("-")).slice(0, 3).map((line) => (
              <li class="text-sm leading-relaxed text-zinc-400">{line.replace(/^-\s*/, "").trim()}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</AppShell>
