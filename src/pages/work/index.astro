---
import AppShell from "../../layouts/AppShell.astro";
import { getCollection } from "astro:content";

const workEntries = await getCollection("work");
const sortedHistory = workEntries.sort((a, b) => 
  new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime()
);
---

<AppShell activePath="/work" pageTitle="Work | Kaka Ruto" pageDescription="Work experience by Kaka Ruto.">
  <section class="min-h-screen border-x border-zinc-800 bg-black/95 px-5 py-8 pb-20 lg:pb-8">
    <header class="border-b border-zinc-800 pb-6">
      <h2 class="text-2xl font-bold text-zinc-50">Work</h2>
      <p class="mt-2 text-zinc-400">A timeline of my professional journey.</p>
    </header>
    
    <div class="-mx-5">
      {sortedHistory.map((entry, i) => (
        <div class:list={["px-5 py-5", i < sortedHistory.length - 1 && "border-b border-zinc-800"]}>
          <div class="flex items-baseline justify-between gap-x-4">
            <div class="flex items-baseline gap-3">
              <h3 class="text-base font-semibold text-sky-400">{entry.data.company}</h3>
              <span class="text-zinc-200">- {entry.data.role}</span>
            </div>
            <div class="text-sm text-emerald-400 shrink-0">{entry.data.period}</div>
          </div>
          <p class="mt-1 text-xs text-zinc-400">{entry.data.location}</p>
          
          <ul class="mt-3 space-y-1.5">
            {entry.body.split("\n").filter(line => line.trim().startsWith("-")).slice(0, 3).map((line) => (
              <li class="text-sm leading-relaxed text-zinc-400">{line.replace(/^-\s*/, "").trim()}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</AppShell>
