---
import AppShell from "../../layouts/AppShell.astro";
import { writings } from "../../data/site";

const sortedWritings = [...writings].sort((a, b) => 
  new Date(b.date).getTime() - new Date(a.date).getTime()
);
---

<AppShell activePath="/writing" pageTitle="Writing | Kaka Ruto" pageDescription="Writing and notes by Kaka Ruto.">
  <section class="min-h-screen border-x border-zinc-800 bg-black/95 px-5 py-8 pb-20 lg:pb-8">
    <header class="border-b border-zinc-800 pb-6">
      <h2 class="text-2xl font-bold text-zinc-50">Writing</h2>
      <p class="mt-2 text-zinc-400">Thoughts, notes, and engineering lessons.</p>
    </header>
    
    <div class="-mx-5">
      {sortedWritings.map((item, i) => (
        <div class:list={["px-5 py-5", i < sortedWritings.length - 1 && "border-b border-zinc-800"]}>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <a href={item.url} class="text-base font-semibold text-sky-400">{item.title}</a>
            <time class="text-sm text-zinc-500">{item.date}</time>
          </div>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">{item.summary}</p>
        </div>
      ))}
    </div>
  </section>
</AppShell>